# jarvis-os IronClaw env defaults — copiar a ~/.ironclaw/.env y editar API keys.
DATABASE_BACKEND=libsql
LIBSQL_PATH=/home/jarvis/.ironclaw/jarvis.db
AGENT_NAME=jarvis
HEARTBEAT_ENABLED=false
IRONCLAW_PROFILE=local
# DATABASE_URL deliberadamente ausente: con backend=libsql, el wizard
# postgres se dispara si la variable está presente (incluso a un valor
# placeholder). LIBSQL_PATH basta para resolver la conexión.

# ─── LLM ───
LLM_PROVIDER=anthropic
LLM_MODEL_CLAUDE=claude-sonnet-4-6
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY_HERE

# ─── Voice (ElevenLabs Conversational AI) ───
# Usado por crates/jarvis_voice_daemon. La key se lee también por el
# unit `jarvis-voice-daemon.service` vía EnvironmentFile=.
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_KEY_HERE
ELEVENLABS_AGENT_ID=agent_6301kq6xj7aqfydbf64ejkx3x8ds

# Variables dinámicas que el agente exige en `conversation_initiation_client_data`.
# Si declaras placeholders {{display_name}}, {{foo}}, etc. en el system prompt
# del agente en consola, debes pasarlas aquí. Sintaxis: "key=value,key=value".
JARVIS_VOICE_VARS=display_name=Horelvis

# Voice ID y Model ID son legacy (TTS Flash directo); el agente ya
# trae voz/modelo configurados en su consola, no hace falta aquí.
# ELEVENLABS_VOICE_ID=...
# ELEVENLABS_MODEL_ID=eleven_flash_v2_5
